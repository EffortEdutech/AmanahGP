# =============================================================
# AmanahHub (apps/user) — .env.example
# Copy to .env.local (never commit .env.local)
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-here

# ── App Identity ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AmanahHub
NEXT_PUBLIC_PLATFORM_NAME=Amanah Governance Platform
NEXT_PUBLIC_APP_URL=http://localhost:3300

# ── Payment Gateway ──────────────────────────────────────────
NEXT_PUBLIC_TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com

# ── Internal (server-side only, never NEXT_PUBLIC_) ──────────
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-here
TOYYIBPAY_USER_SECRET_KEY=your-toyyibpay-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_WEBHOOK_SECRET=your-webhook-signing-secret
