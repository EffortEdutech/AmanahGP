# amanahOS — Governance Workspace for Organizations
# apps/org/.env.local (copy this file, fill in values, never commit .env.local)

# ── Supabase ──────────────────────────────────────────────────────────────────
# Same Supabase project as apps/user and apps/admin
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Service role key — server-side only, never prefix with NEXT_PUBLIC_
# Used only in API routes and server actions that require service-role access
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── App identity ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=amanahOS
NEXT_PUBLIC_APP_FULL_NAME=amanahOS — Governance Workspace
NEXT_PUBLIC_PLATFORM_NAME=Amanah Governance Platform
NEXT_PUBLIC_APP_URL=http://localhost:3302

# ── Sibling app URLs ──────────────────────────────────────────────────────────
# Used for cross-app navigation links
NEXT_PUBLIC_HUB_URL=http://localhost:3300
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3301

# ── Production (fill in for Vercel deployment) ────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://uscgtpvdgcgrfzvccnwq.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
# NEXT_PUBLIC_APP_URL=https://org.amanahhub.my
# NEXT_PUBLIC_HUB_URL=https://amanahhub.my
# NEXT_PUBLIC_CONSOLE_URL=https://console.amanahhub.my
