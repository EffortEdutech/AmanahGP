# =============================================================
# Amanah Governance Platform — Root .env.example
# Copy to .env.local (never commit .env.local)
# =============================================================

# ── Supabase (shared, resolved from `supabase status`) ───────
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=your-local-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-here

# ── Payment Gateway — ToyyibPay ───────────────────────────────
# Obtain sandbox credentials from https://toyyibpay.com
TOYYIBPAY_USER_SECRET_KEY=your-toyyibpay-secret-key
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_WEBHOOK_SECRET=your-webhook-signing-secret
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com

# ── Platform Config ───────────────────────────────────────────
PLATFORM_NAME=Amanah Governance Platform
NODE_ENV=development
