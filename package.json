{
  "name": "amanah-governance-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Amanah Governance Platform — Trusted Giving. Transparent Governance.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:user":   "pnpm -C apps/user dev -- -p 3300",
    "dev:admin":  "pnpm -C apps/admin dev -- -p 3301",
    "dev":        "concurrently \"pnpm dev:user\" \"pnpm dev:admin\"",
    "build:user": "pnpm -C apps/user build",
    "build:admin":"pnpm -C apps/admin build",
    "build":      "pnpm build:user && pnpm build:admin",
    "lint":       "pnpm -r lint",
    "typecheck":  "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
